{
  "ConnectionStrings": {
    "Redis": "redis:6379",
    "Hangfire": "Host=postgres;Database=dashboard;Username=postgres;Password=postgres"
  },
  "Jwt": { "Issuer": "sales-api", "Audience": "sales-clients", "Key": "local-development-key-change-before-production" },
  "Seq": { "Url": "http://seq:5341" },
  "Downstream": { "SalesBaseUrl": "", "InventoryBaseUrl": "" },
  "ServiceAccount": { "UserName": "", "Password": "", "AllowAdminDevFallback": false },
  "Dashboard": {
    "Cache": { "Key": "dashboard:snapshot", "TtlSeconds": 300, "UseRedis": true },
    "RefreshJob": { "Enabled": true, "Cron": "* * * * *", "Queue": "default" },
    "Inventory": { "LowStockThreshold": 5 }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Serilog": { "MinimumLevel": { "Default": "Information" } },
  "HttpLogging": {
    "LogRequestBody": true,
    "LogResponseBody": false,
    "MaxBodyBytes": 8192,
    "SensitiveHeaders": ["Authorization", "Cookie", "Set-Cookie"],
    "SensitiveJsonFields": ["password", "token", "accessToken", "refreshToken", "secret", "currentPassword", "newPassword"]
  },
  "AllowedHosts": "*"
}
