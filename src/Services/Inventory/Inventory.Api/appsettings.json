{
  "ConnectionStrings": {
    "Inventory": "Host=postgres;Database=inventory;Username=postgres;Password=postgres",
    "InventoryHangfire": "Host=postgres;Database=inventory_hangfire;Username=postgres;Password=postgres",
    "Redis": "redis:6379"
  },
  "Inventory": { "Summary": { "LowStockThreshold": 5 } },
  "Kafka": { "Brokers": ["kafka:9092"] },
  "InventoryRecurringJobs": {
    "ReplayDeadLetter": {
      "Schedule": {
        "Enabled": true,
        "Queue": "maintenance",
        "Cron": "*/15 * * * *"
      },
      "BatchSize": 100,
      "RetryDelaySeconds": 0
    },
    "KafkaLagMonitor": {
      "Schedule": {
        "Enabled": true,
        "Queue": "maintenance",
        "Cron": "*/5 * * * *"
      },
      "GroupId": "inventory-orders-v1",
      "Topics": [
        "sales.order-confirmation-requested.v1",
        "sales.order-undo-confirmation-requested.v1"
      ],
      "WarningThreshold": 100,
      "RequestTimeoutSeconds": 10
    },
    "InboxCleanup": {
      "Schedule": {
        "Enabled": true,
        "Queue": "maintenance",
        "Cron": "0 1 * * *"
      },
      "BatchSize": 500,
      "RetentionDays": 14
    },
    "FailedOutboxRetry": {
      "Schedule": {
        "Enabled": true,
        "Queue": "maintenance",
        "Cron": "*/15 * * * *"
      },
      "BatchSize": 100,
      "RetryDelaySeconds": 0
    },
    "OutboxPendingMonitor": {
      "Schedule": {
        "Enabled": true,
        "Queue": "maintenance",
        "Cron": "*/5 * * * *"
      },
      "BacklogWarningThreshold": 100,
      "OldestPendingWarningSeconds": 300
    }
  },
  "Jwt": { "Issuer": "sales-api", "Audience": "sales-clients", "Key": "local-development-key-change-before-production" },
  "Seq": { "Url": "http://seq:5341" },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Serilog": { "MinimumLevel": { "Default": "Information", "Override": { "Microsoft.EntityFrameworkCore.Database.Command": "Warning" } } },
  "HttpLogging": {
    "LogRequestBody": true,
    "LogResponseBody": false,
    "MaxBodyBytes": 8192,
    "SensitiveHeaders": ["Authorization", "Cookie", "Set-Cookie"],
    "SensitiveJsonFields": ["password", "token", "accessToken", "refreshToken", "secret", "currentPassword", "newPassword"]
  },
  "AllowedHosts": "*"
}
